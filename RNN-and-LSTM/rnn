class RNNLanguageModel:
    """RNN-based language model for text generation."""

    def __init__(self, vocab_size: int, hidden_dim: int, cell_type: str = 'vanilla'):
        """
        Initialize language model.

        Args:
            vocab_size: Size of vocabulary
            hidden_dim: Hidden dimension
            cell_type: Type of RNN cell ('vanilla', 'lstm', 'gru')
        """
        self.vocab_size = vocab_size
        self.hidden_dim = hidden_dim
        self.cell_type = cell_type

        # Initialize embedding layer
        self.embedding = np.random.randn(vocab_size, hidden_dim) * 0.01

        # Initialize RNN cell
        if cell_type == 'vanilla':
            self.cell = VanillaRNNCell(hidden_dim, hidden_dim)
        elif cell_type == 'lstm':
            self.cell = LSTMCell(hidden_dim, hidden_dim)
        elif cell_type == 'gru':
            self.cell = GRUCell(hidden_dim, hidden_dim)
        else:
            raise ValueError(f"Unknown cell type: {cell_type}")

        # Output projection
        self.output_proj = np.random.randn(hidden_dim, vocab_size) * 0.01
        self.output_bias = np.zeros(vocab_size)

    def forward(self, input_ids: np.ndarray, initial_state: Optional[np.ndarray] = None) -> Tuple[
        np.ndarray, np.ndarray]:
        """
        Forward pass through language model.

        Args:
            input_ids: Input token IDs [batch_size, seq_len]
            initial_state: Initial hidden state (optional)

        Returns:
            logits: Output logits [batch_size, seq_len, vocab_size]
            hidden_states: Hidden states [batch_size, seq_len, hidden_dim]
        """
        batch_size, seq_len = input_ids.shape

        # Embed inputs
        embedded = self.embedding[input_ids]  # [batch_size, seq_len, hidden_dim]

        # Initialize hidden state
        h = initial_state if initial_state is not None else np.zeros((batch_size, self.hidden_dim))
        if self.cell_type == 'lstm':
            c = np.zeros((batch_size, self.hidden_dim))

        # Process sequence and cache for backward
        hidden_states = []
        caches = []

        for t in range(seq_len):
            x_t = embedded[:, t, :]
            if self.cell_type == 'lstm':
                h, c, cache = self.cell.forward(x_t, h, c)
            else:
                h, cache = self.cell.forward(x_t, h)
            hidden_states.append(h)
            caches.append(cache)

        hidden_states = np.stack(hidden_states, axis=1)  # [batch_size, seq_len, hidden_dim]

        # Project to vocabulary
        logits = np.dot(hidden_states, self.output_proj) + self.output_bias  # [batch_size, seq_len, vocab_size]

        # Store cache for backward pass
        self._last_cache = {
            'input_ids': input_ids,
            'embedded': embedded,
            'hidden_states': hidden_states,
            'caches': caches,
            'cell_type': self.cell_type
        }

        return logits, hidden_states

    def generate(self, prompt_ids: np.ndarray, max_length: int, temperature: float = 1.0) -> np.ndarray:
        """
        Generate text from prompt.

        Args:
            prompt_ids: Prompt token IDs [1, prompt_len]
            max_length: Maximum generation length
            temperature: Sampling temperature

        Returns:
            generated_ids: Generated token IDs [1, max_length]
        """
        if prompt_ids.ndim != 2 or prompt_ids.shape[0] != 1:
            raise ValueError("prompt_ids must have shape [1, prompt_len]")

        prompt_len = prompt_ids.shape[1]
        generated = list(prompt_ids[0])

        h = np.zeros((1, self.hidden_dim), dtype=np.float32)
        if self.cell_type == "lstm":
            c = np.zeros((1, self.hidden_dim), dtype=np.float32)

        # Process prompt
        for t in range(min(prompt_len, len(generated))):
            token_id = generated[t]
            if token_id >= self.vocab_size:
                token_id = 0  # Use PAD token if out of bounds
            x_t = self.embedding[token_id:token_id + 1]  # [1, hidden_dim]
            if self.cell_type == "lstm":
                h, c, _ = self.cell.forward(x_t, h, c)
            else:
                h, _ = self.cell.forward(x_t, h)

        # Generate tokens
        for _ in range(max_length - prompt_len):
            # Get last token
            last_token = generated[-1]
            if last_token >= self.vocab_size:
                last_token = 0

            x_t = self.embedding[last_token:last_token + 1]
            if self.cell_type == "lstm":
                h, c, _ = self.cell.forward(x_t, h, c)
            else:
                h, _ = self.cell.forward(x_t, h)

            logits = np.dot(h, self.output_proj) + self.output_bias  # [1, vocab_size]

            if temperature <= 0:
                raise ValueError("temperature must be > 0")

            # Temperature scaling and sampling
            scaled = logits / temperature
            scaled = scaled - np.max(scaled)
            exp_scaled = np.exp(scaled)
            probs = exp_scaled / (np.sum(exp_scaled) + 1e-9)

            # Sample token
            next_token = np.random.choice(self.vocab_size, p=probs.flatten())
            generated.append(int(next_token))

        return np.array([generated[:max_length]], dtype=np.int32)

    def beam_search(self, prompt_ids: np.ndarray, max_length: int, beam_width: int = 5) -> np.ndarray:
        """
        Generate text using beam search decoding.

        Args:
            prompt_ids: Prompt token IDs [1, prompt_len]
            max_length: Maximum generation length
            beam_width: Number of beams to maintain

        Returns:
            best_sequence: Best generated sequence [1, max_length]
        """
        if prompt_ids.ndim != 2 or prompt_ids.shape[0] != 1:
            raise ValueError("prompt_ids must have shape [1, prompt_len]")

        prompt_len = prompt_ids.shape[1]

        initial_h = np.zeros((1, self.hidden_dim), dtype=np.float32)
        h = initial_h.copy()
        c = None
        if self.cell_type == "lstm":
            c = np.zeros((1, self.hidden_dim), dtype=np.float32)

        prompt_tokens = list(prompt_ids[0])
        for t in range(prompt_len):
            token_id = prompt_tokens[t]
            if token_id >= self.vocab_size:
                token_id = 0
            x_t = self.embedding[token_id:token_id + 1]
            if self.cell_type == "lstm":
                h, c, _ = self.cell.forward(x_t, h, c)
            else:
                h, _ = self.cell.forward(x_t, h)

        if self.cell_type == "lstm":
            beams = [(prompt_tokens.copy(), 0.0, h.copy(), c.copy())]
        else:
            beams = [(prompt_tokens.copy(), 0.0, h.copy(), None)]

        for _ in range(max_length - prompt_len):
            candidates = []

            for seq, score, h_state, c_state in beams:
                last_token = seq[-1]
                if last_token >= self.vocab_size:
                    last_token = 0

                x_t = self.embedding[last_token:last_token + 1]
                h_new = h_state.copy()
                c_new = c_state.copy() if c_state is not None else None

                if self.cell_type == "lstm":
                    h_new, c_new, _ = self.cell.forward(x_t, h_new, c_new)
                else:
                    h_new, _ = self.cell.forward(x_t, h_new)

                logits = np.dot(h_new, self.output_proj) + self.output_bias
                log_probs = logits - np.log(np.sum(np.exp(logits)) + 1e-9)

                top_k = min(beam_width, self.vocab_size)
                top_indices = np.argsort(log_probs[0])[-top_k:]

                for idx in top_indices:
                    new_seq = seq + [int(idx)]
                    new_score = score + log_probs[0, idx]
                    candidates.append(
                        (new_seq, new_score, h_new.copy(), c_new.copy() if c_new is not None else None)
                    )

            candidates.sort(key=lambda x: x[1], reverse=True)
            beams = candidates[:beam_width]

        best_seq = beams[0][0][:max_length]
        return np.array([best_seq], dtype=np.int32)



class BiLSTMClassifier:
    """Bidirectional LSTM for sentiment classification."""

    def __init__(self, vocab_size: int, hidden_dim: int, num_classes: int, use_attention: bool = True):
        """
        Initialize classifier.

        Args:
            vocab_size: Size of vocabulary
            hidden_dim: Hidden dimension
            num_classes: Number of output classes
            use_attention: Whether to use attention mechanism
        """
        self.vocab_size = vocab_size
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        self.use_attention = use_attention

        # Initialize components
        self.embedding = np.random.randn(vocab_size, hidden_dim) * 0.01
        self.lstm_forward = LSTMCell(hidden_dim, hidden_dim)
        self.lstm_backward = LSTMCell(hidden_dim, hidden_dim)

        if use_attention:
            self.attention = MultiHeadSelfAttention(hidden_dim * 2, num_heads=4)

        self.classifier = np.random.randn(hidden_dim * 2, num_classes) * 0.01

    def forward(self, input_ids: np.ndarray, lengths: np.ndarray) -> np.ndarray:
        """
        Forward pass through classifier.

        Args:
            input_ids: Input token IDs [batch_size, max_seq_len]
            lengths: Actual sequence lengths [batch_size]

        Returns:
            logits: Classification logits [batch_size, num_classes]
        """
        batch_size, max_seq_len = input_ids.shape

        # Embed inputs
        embedded = self.embedding[input_ids]  # [batch_size, max_seq_len, hidden_dim]

        # Forward LSTM
        h_fwd = np.zeros((batch_size, self.hidden_dim))
        c_fwd = np.zeros((batch_size, self.hidden_dim))
        forward_outputs = []
        for t in range(max_seq_len):
            h_fwd, c_fwd, _ = self.lstm_forward.forward(embedded[:, t, :], h_fwd, c_fwd)
            forward_outputs.append(h_fwd)
        forward_outputs = np.stack(forward_outputs, axis=1)  # [batch_size, max_seq_len, hidden_dim]

        # Backward LSTM
        h_bwd = np.zeros((batch_size, self.hidden_dim))
        c_bwd = np.zeros((batch_size, self.hidden_dim))
        backward_outputs = []
        for t in range(max_seq_len - 1, -1, -1):
            h_bwd, c_bwd, _ = self.lstm_backward.forward(embedded[:, t, :], h_bwd, c_bwd)
            backward_outputs.insert(0, h_bwd)
        backward_outputs = np.stack(backward_outputs, axis=1)  # [batch_size, max_seq_len, hidden_dim]

        # Concatenate forward and backward
        combined = np.concatenate([forward_outputs, backward_outputs],
                                  axis=-1)  # [batch_size, max_seq_len, hidden_dim * 2]

        # Apply attention if enabled
        if self.use_attention:
            # Create mask: 0 where valid, 1 where padding
            mask = np.zeros((batch_size, max_seq_len, max_seq_len))
            for i, length in enumerate(lengths):
                # Mask out padding positions
                mask[i, :, length:] = 1  # Mask padding in keys
                mask[i, length:, :] = 1  # Mask padding in queries

            combined, _ = self.attention.forward(combined, mask)

        # Get final representation (use last valid position for each sequence)
        final_repr = np.zeros((batch_size, self.hidden_dim * 2))
        for i, length in enumerate(lengths):
            final_repr[i] = combined[i, length - 1, :]

        # Classify
        logits = np.dot(final_repr, self.classifier)  # [batch_size, num_classes]

        return logits


# ==================== Part 4: Text Processing Utilities ====================

class TextProcessor:
    """Utilities for text processing."""

    def __init__(self, level: str = 'char'):
        """
        Initialize text processor.

        Args:
            level: Tokenization level ('char' or 'word')
        """
        self.level = level
        self.vocab = {}
        self.reverse_vocab = {}
        self.vocab_size = 0

        # Special tokens
        self.PAD = "<PAD>"
        self.UNK = "<UNK>"
        self.SOS = "<SOS>"
        self.EOS = "<EOS>"

    def build_vocab(self, texts: List[str], min_freq: int = 1):
        """
        Build vocabulary from texts.

        Args:
            texts: List of text strings
            min_freq: Minimum frequency for inclusion
        """
        from collections import Counter

        # Tokenize texts
        tokens = []
        for text in texts:
            if self.level == 'char':
                tokens.extend(list(text))
            else:  # word level
                tokens.extend(text.strip().split())

        # Count frequencies
        freq = Counter(tokens)

        # Start with special tokens
        vocab = [self.PAD, self.UNK, self.SOS, self.EOS]

        # Add tokens meeting minimum frequency
        for token, count in freq.items():
            if count >= min_freq and token not in vocab:
                vocab.append(token)

        # Create mappings
        self.vocab = {token: idx for idx, token in enumerate(vocab)}
        self.reverse_vocab = {idx: token for token, idx in self.vocab.items()}
        self.vocab_size = len(vocab)

    def encode(self, text: str) -> np.ndarray:
        """
        Convert text to token IDs.

        Args:
            text: Input text

        Returns:
            token_ids: Array of token IDs
        """
        if self.level == 'char':
            tokens = list(text)
        else:  # word level
            tokens = text.strip().split()

        # Convert tokens to IDs
        ids = []
        for token in tokens:
            ids.append(self.vocab.get(token, self.vocab.get(self.UNK)))

        return np.array(ids, dtype=np.int32)

    def decode(self, token_ids: np.ndarray) -> str:
        """
        Convert token IDs back to text.

        Args:
            token_ids: Array of token IDs

        Returns:
            text: Decoded text
        """
        tokens = []
        for idx in token_ids:
            token = self.reverse_vocab.get(int(idx), self.UNK)
            # Skip special tokens in output
            if token not in [self.PAD, self.SOS, self.EOS, self.UNK]:
                tokens.append(token)
            elif token == self.EOS:
                break

        if self.level == 'char':
            return ''.join(tokens)
        else:  # word level
            return ' '.join(tokens)

    def create_batches(self, texts: List[str], batch_size: int, max_length: Optional[int] = None) -> List[Dict]:
        """
        Create batched data for training.

        Args:
            texts: List of texts
            batch_size: Batch size
            max_length: Maximum sequence length (optional)

        Returns:
            batches: List of batch dictionaries
        """
        # Encode all texts
        encoded = [self.encode(text) for text in texts]

        # Determine max length
        if max_length is None:
            max_length = max(len(seq) for seq in encoded) if encoded else 1

        # Create batches
        batches = []
        for i in range(0, len(encoded), batch_size):
            batch_seqs = encoded[i:i + batch_size]
            batch_size_actual = len(batch_seqs)

            # Pad sequences
            lengths = np.array([min(len(seq), max_length) for seq in batch_seqs], dtype=np.int32)
            input_ids = np.full((batch_size_actual, max_length), self.vocab.get(self.PAD), dtype=np.int32)

            for j, seq in enumerate(batch_seqs):
                trunc = seq[:max_length]
                input_ids[j, :len(trunc)] = trunc

            # Create mask
            mask = (input_ids != self.vocab.get(self.PAD)).astype(np.int32)

            batches.append({
                'input_ids': input_ids,
                'lengths': lengths,
                'mask': mask
            })

        return batches


# ==================== Part 5: Training Utilities ====================

def truncated_bptt(loss_fn, model, sequences, k1: int = 20, k2: int = 5):
    """
    Implement Truncated Backpropagation Through Time.

    Args:
        loss_fn: Loss function
        model: RNN model
        sequences: Input sequences
        k1: Forward pass truncation length
        k2: Backward pass truncation length
    """

    total_loss = 0.0
    h = model.init_hidden()  # initial hidden state

    # iterate through sequence in windows of k1
    for start in range(0, len(sequences), k1):
        end = start + k1
        window = sequences[start:end]

        # store forward pass values for this window
        states = []  # (h_t, x_t)
        outputs = []  # model predictions
        # forward pass
        for x_t, y_t in window:
            h = model.forward_step(x_t, h)
            y_pred = model.output(h)

            states.append((h, x_t))
            outputs.append((y_pred, y_t))

        # compute window loss
        window_loss = 0.0
        for y_pred, y_t in outputs:
            window_loss += loss_fn(y_pred, y_t)

        total_loss += window_loss

        dh_next = None

        for i in range(len(states) - 1, -1, -1):
            if (len(states) - i) > k2:
                break  # stop after k2 backward steps

            h_t, x_t = states[i]
            y_pred, y_true = outputs[i]

            # gradient of loss wrt model output
            dLdy = loss_fn.grad(y_pred, y_true)

            # one step of RNN backward through time
            dh_next = model.backward_step(dLdy, h_t, x_t, dh_next)

        # after backprop through this window, update parameters
        model.update_params()

        # hidden state detachment (stop gradient history)
        h = h.copy()

    return total_loss


def gradient_clipping(gradients: Dict[str, np.ndarray], max_norm: float = 5.0) -> Dict[str, np.ndarray]:
    """
    Clip gradients by global norm.

    Args:
        gradients: Dictionary of gradients
        max_norm: Maximum gradient norm

    Returns:
        clipped_gradients: Clipped gradients
    """
    # Compute global norm
    total_norm = 0.0
    for grad in gradients.values():
        total_norm += np.sum(grad ** 2)
    total_norm = np.sqrt(total_norm)

    # Clip if norm exceeds max_norm
    if total_norm > max_norm:
        clip_factor = max_norm / (total_norm + 1e-8)
        clipped_gradients = {k: v * clip_factor for k, v in gradients.items()}
    else:
        clipped_gradients = gradients.copy()

    return clipped_gradients


# ==================== Part 6: Evaluation Metrics ====================

def compute_perplexity(logits: np.ndarray, targets: np.ndarray, lengths: np.ndarray) -> float:
    """
    Compute perplexity for language modeling.

    Args:
        logits: Model predictions [batch_size, seq_len, vocab_size]
        targets: Target token IDs [batch_size, seq_len]
        lengths: Actual sequence lengths [batch_size]

    Returns:
        perplexity: Perplexity score
    """
    batch_size, seq_len, vocab_size = logits.shape

    # Compute probabilities
    probs = np.exp(logits - np.max(logits, axis=-1, keepdims=True))
    probs = probs / np.sum(probs, axis=-1, keepdims=True)

    # Gather log probabilities of targets
    log_probs = []
    for i in range(batch_size):
        for t in range(lengths[i]):
            prob = probs[i, t, targets[i, t]]
            log_prob = np.log(prob + 1e-9)
            log_probs.append(log_prob)

    # Compute average log probability
    avg_log_prob = np.mean(log_probs) if log_probs else 0.0

    # Perplexity is exp of negative average log probability
    perplexity = np.exp(-avg_log_prob)

    return float(perplexity)


def compute_bleu_score(predictions: List[str], references: List[str], n: int = 4) -> float:
    """
    Compute BLEU score for generated text.

    Args:
        predictions: List of predicted texts
        references: List of reference texts
        n: Maximum n-gram order

    Returns:
        bleu_score: BLEU score
    """
    import collections

    def ngrams(sequence, n):
        """Generate n-grams from a sequence."""
        return [tuple(sequence[i:i + n]) for i in range(len(sequence) - n + 1)]

    scores = []
    for pred, ref in zip(predictions, references):
        pred_tokens = pred.split()
        ref_tokens = ref.split()

        precisions = []
        for k in range(1, n + 1):
            pred_ng = ngrams(pred_tokens, k)
            ref_ng = ngrams(ref_tokens, k)

            pred_counts = collections.Counter(pred_ng)
            ref_counts = collections.Counter(ref_ng)

            overlap = sum((pred_counts & ref_counts).values())
            total_pred = max(1, sum(pred_counts.values()))

            precisions.append(overlap / total_pred)

        # Brevity penalty
        bp = min(1.0, np.exp(1 - len(ref_tokens) / max(1, len(pred_tokens))))

        # Geometric mean of precisions
        score = bp * np.exp(np.mean([np.log(p + 1e-9) for p in precisions]))
        scores.append(score)

    return float(np.mean(scores)) if scores else 0.0


# ==================== Data Loading Functions ====================

def load_shakespeare_data(filepath: str = 'shakespeare.txt') -> str:
    """
    Load Shakespeare text data for text generation.

    Args:
        filepath: Path to shakespeare.txt file

    Returns:
        text: Complete text as a string
    """
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            text = f.read()
        return text
    except FileNotFoundError:
        print(f"Error: Could not find {filepath}")
        return ""


def load_review_data(filepath: str = 'reviews.csv') -> List[Tuple[str, int]]:
    """
    Load movie review data for sentiment analysis.

    Args:
        filepath: Path to reviews.csv file

    Returns:
        data: List of (review_text, label) tuples
    """
    import csv

    data = []
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            for row in reader:
                text = row['text']
                label = int(row['label'])
                data.append((text, label))
        return data
    except FileNotFoundError:
        print(f"Error: Could not find {filepath}")
        return []
    except KeyError:
        print("Error: CSV file should have 'text' and 'label' columns")
        return []


def prepare_shakespeare_dataset(text: str, seq_len: int = 100, overlap: int = 50) -> List[Tuple[str, str]]:
    """
    Prepare Shakespeare text for training by creating overlapping sequences.

    Args:
        text: Complete text
        seq_len: Length of each sequence
        overlap: Number of overlapping characters between sequences

    Returns:
        sequences: List of (input, target) sequence pairs
    """
    sequences = []
    stride = seq_len - overlap

    for i in range(0, len(text) - seq_len - 1, stride):
        input_seq = text[i:i + seq_len]
        target_seq = text[i + 1:i + seq_len + 1]
        sequences.append((input_seq, target_seq))

    return sequences


def split_review_data(data: List[Tuple[str, int]],
                      train_ratio: float = 0.8,
                      seed: int = 42) -> Tuple[List[Tuple[str, int]], List[Tuple[str, int]]]:
    """
    Split review data into training and validation sets.

    Args:
        data: Complete dataset
        train_ratio: Proportion of data for training
        seed: Random seed for reproducibility

    Returns:
        train_data: Training set
        val_data: Validation set
    """
    np.random.seed(seed)

    # Shuffle the data
    indices = np.arange(len(data))
    np.random.shuffle(indices)

    # Split
    train_size = int(len(data) * train_ratio)
    train_indices = indices[:train_size]
    val_indices = indices[train_size:]

    train_data = [data[i] for i in train_indices]
    val_data = [data[i] for i in val_indices]

    return train_data, val_data


# ==================== Main Training Script ====================

def train_language_model(model: RNNLanguageModel, train_data: List[str],
                         val_data: List[str], config: Dict) -> Dict:
    """
    Train language model with proper gradient descent.

    Args:
        model: Language model
        train_data: Training texts
        val_data: Validation texts
        config: Training configuration

    Returns:
        results: Training results and metrics
    """
    print("\n" + "=" * 60)
    print("TRAINING LANGUAGE MODEL")
    print("=" * 60)

    # Configuration
    num_epochs = config.get('num_epochs', 20)
    batch_size = config.get('batch_size', 16)
    seq_len = config.get('seq_len', 40)
    learning_rate = config.get('learning_rate', 0.005)
    clip_norm = config.get('clip_norm', 5.0)

    # Create processor
    processor = TextProcessor(level='char')
    processor.build_vocab([train_data])
    print(f"Vocabulary size: {processor.vocab_size}")

    # Recreate model with correct vocab size
    model = RNNLanguageModel(processor.vocab_size, model.hidden_dim, model.cell_type)

    # Prepare training sequences
    print(f"Preparing training sequences (seq_len={seq_len})...")
    train_sequences = prepare_shakespeare_dataset(train_data, seq_len=seq_len, overlap=seq_len // 2)
    print(f"Created {len(train_sequences)} training sequences")

    results = {
        'train_loss': [],
        'val_loss': [],
        'train_perplexity': [],
        'val_perplexity': [],
        'generated_samples': [],
        'model': model,
        'processor': processor
    }

    best_val_loss = float('inf')
    patience = 3
    patience_counter = 0
    current_lr = learning_rate

    # Training loop
    for epoch in range(num_epochs):
        epoch_loss = 0.0
        num_batches = 0

        # Shuffle sequences
        np.random.shuffle(train_sequences)

        # Mini-batch training with actual gradient descent
        for i in range(0, len(train_sequences), batch_size):
            batch_sequences = train_sequences[i:i + batch_size]

            # Prepare batch
            batch_inputs = []
            batch_targets = []

            for input_seq, target_seq in batch_sequences:
                input_ids = processor.encode(input_seq)
                target_ids = processor.encode(target_seq)
                batch_inputs.append(input_ids)
                batch_targets.append(target_ids)

            # Pad to same length
            max_len = max(len(seq) for seq in batch_inputs)
            input_batch = np.zeros((len(batch_inputs), max_len), dtype=np.int32)
            target_batch = np.zeros((len(batch_targets), max_len), dtype=np.int32)
            lengths = np.array([len(seq) for seq in batch_inputs], dtype=np.int32)

            for j, (inp, tgt) in enumerate(zip(batch_inputs, batch_targets)):
                input_batch[j, :len(inp)] = inp
                target_batch[j, :len(tgt)] = tgt

            # Forward pass
            logits, _ = model.forward(input_batch)

            # Compute loss and gradients
            batch_loss, dlogits = _compute_loss_and_gradients(
                logits, target_batch, lengths, processor.vocab.get('<PAD>', 0)
            )

            # Backward pass through time
            if hasattr(model, '_last_cache'):
                _backward_through_time(model, dlogits, model._last_cache)

            # Gradient clipping
            _clip_model_gradients(model, clip_norm)

            # Update parameters with SGD
            _sgd_update(model, current_lr)

            epoch_loss += batch_loss
            num_batches += 1

        # Average epoch loss
        avg_train_loss = epoch_loss / num_batches if num_batches > 0 else 0.0
        results['train_loss'].append(avg_train_loss)

        # Compute perplexity
        train_perplexity = np.exp(np.clip(avg_train_loss, 0, 10))
        results['train_perplexity'].append(train_perplexity)

        # Validation
        val_loss = _evaluate_language_model(model, val_data, processor, seq_len)
        results['val_loss'].append(val_loss)
        val_perplexity = np.exp(np.clip(val_loss, 0, 10))
        results['val_perplexity'].append(val_perplexity)

        # Learning rate scheduling
        if val_loss < best_val_loss - 0.01:
            best_val_loss = val_loss
            patience_counter = 0
        else:
            patience_counter += 1
            if patience_counter >= patience:
                current_lr *= 0.5
                patience_counter = 0
                if current_lr < 1e-5:
                    print(f"\nLearning rate too small, stopping early at epoch {epoch + 1}")
                    break
                print(f"\nReducing learning rate to {current_lr:.6f}")

        # Generate sample text
        if epoch % 3 == 0 or epoch == num_epochs - 1:
            prompt = "To be, or not to be"
            try:
                prompt_ids = processor.encode(prompt)[np.newaxis, :]
                if prompt_ids.shape[1] > 0:
                    generated_ids = model.generate(prompt_ids, max_length=80, temperature=0.7)
                    sample = processor.decode(generated_ids[0])
                    results['generated_samples'].append(sample)
                    print(f"\nEpoch {epoch + 1} - Sample: {sample[:70]}...")
            except Exception as e:
                print(f"\nEpoch {epoch + 1} - Generation failed: {e}")

        # Print progress
        print(f"Epoch {epoch + 1}/{num_epochs} - "
              f"Loss: {avg_train_loss:.4f}, PPL: {train_perplexity:.2f}, "
              f"Val Loss: {val_loss:.4f}, Val PPL: {val_perplexity:.2f}, "
              f"LR: {current_lr:.6f}")

    print("\n" + "=" * 60)
    print("Language Model Training Complete!")
    print("=" * 60)

    results['model'] = model
    results['processor'] = processor
    return results


def train_classifier(model: BiLSTMClassifier, train_data: List[Tuple[str, int]],
                     val_data: List[Tuple[str, int]], config: Dict) -> Dict:
    """
    Train sentiment classifier with proper gradient descent.

    Args:
        model: Classifier model
        train_data: Training data (text, label) pairs
        val_data: Validation data
        config: Training configuration

    Returns:
        results: Training results and metrics
    """
    print("\n" + "=" * 60)
    print("TRAINING SENTIMENT CLASSIFIER")
    print("=" * 60)

    # Configuration
    num_epochs = config.get('num_epochs', 20)
    batch_size = config.get('batch_size', 4)
    max_length = config.get('max_length', 100)
    learning_rate = config.get('learning_rate', 0.01)
    clip_norm = config.get('clip_norm', 5.0)

    # Create processor
    processor = TextProcessor(level='word')
    all_texts = [text for text, _ in train_data] + [text for text, _ in val_data]
    processor.build_vocab(all_texts, min_freq=1)
    print(f"Vocabulary size: {processor.vocab_size}")

    # Recreate model with correct vocab size
    model = BiLSTMClassifier(
        processor.vocab_size, model.hidden_dim,
        model.num_classes, model.use_attention
    )

    results = {
        'train_loss': [],
        'val_loss': [],
        'train_accuracy': [],
        'val_accuracy': [],
        'confusion_matrix': None,
        'model': model,
        'processor': processor
    }

    best_val_acc = 0.0
    patience = 3
    patience_counter = 0
    current_lr = learning_rate

    # Training loop
    for epoch in range(num_epochs):
        train_losses = []
        train_correct = 0
        train_total = 0

        # Shuffle training data
        indices = np.random.permutation(len(train_data))
        shuffled_data = [train_data[i] for i in indices]

        # Mini-batch training with gradient descent
        for i in range(0, len(shuffled_data), batch_size):
            batch_data = shuffled_data[i:i + batch_size]

            # Prepare batch
            batch_texts = [text for text, _ in batch_data]
            batch_labels = np.array([label for _, label in batch_data], dtype=np.int32)

            # Encode texts
            batch_encoded = [processor.encode(text) for text in batch_texts]
            lengths = np.array([min(len(seq), max_length) for seq in batch_encoded], dtype=np.int32)

            # Pad sequences
            input_ids = np.zeros((len(batch_encoded), max_length), dtype=np.int32)
            for j, seq in enumerate(batch_encoded):
                trunc = seq[:max_length]
                input_ids[j, :len(trunc)] = trunc

            # Forward pass
            logits = model.forward(input_ids, lengths)

            # Compute loss and gradients
            loss, dlogits = _compute_classification_loss_and_gradients(logits, batch_labels)
            train_losses.append(loss)

            # Backward pass (simplified - update only classifier weights)
            # Get the final representations
            batch_size_actual = input_ids.shape[0]
            embedded = model.embedding[input_ids]

            # Forward LSTM (recreate to get final repr)
            h_fwd = np.zeros((batch_size_actual, model.hidden_dim))
            c_fwd = np.zeros((batch_size_actual, model.hidden_dim))
            forward_outputs = []
            for t in range(input_ids.shape[1]):
                h_fwd, c_fwd, _ = model.lstm_forward.forward(embedded[:, t, :], h_fwd, c_fwd)
                forward_outputs.append(h_fwd)
            forward_outputs = np.stack(forward_outputs, axis=1)

            h_bwd = np.zeros((batch_size_actual, model.hidden_dim))
            c_bwd = np.zeros((batch_size_actual, model.hidden_dim))
            backward_outputs = []
            for t in range(input_ids.shape[1] - 1, -1, -1):
                h_bwd, c_bwd, _ = model.lstm_backward.forward(embedded[:, t, :], h_bwd, c_bwd)
                backward_outputs.insert(0, h_bwd)
            backward_outputs = np.stack(backward_outputs, axis=1)

            combined = np.concatenate([forward_outputs, backward_outputs], axis=-1)

            if model.use_attention:
                mask = np.zeros((batch_size_actual, max_length, max_length))
                for j, length in enumerate(lengths):
                    mask[j, :, length:] = 1
                    mask[j, length:, :] = 1
                combined, _ = model.attention.forward(combined, mask)

            # Get final representation
            final_repr = np.zeros((batch_size_actual, model.hidden_dim * 2))
            for j, length in enumerate(lengths):
                final_repr[j] = combined[j, min(length - 1, max_length - 1), :]

            # Update classifier weights
            dclassifier = final_repr.T @ dlogits
            model.classifier -= current_lr * dclassifier

            # Update embeddings (simplified)
            dembedding_grad = dlogits @ model.classifier.T
            for j in range(batch_size_actual):
                length = min(lengths[j], max_length)
                token_grad = dembedding_grad[j] / max(length, 1)
                for t in range(length):
                    token_id = input_ids[j, t]
                    if token_id < model.embedding.shape[0]:
                        model.embedding[token_id] -= current_lr * 0.1 * token_grad[:model.hidden_dim]

            # Compute accuracy
            preds = np.argmax(logits, axis=1)
            train_correct += np.sum(preds == batch_labels)
            train_total += len(batch_labels)

        # Training metrics
        avg_train_loss = np.mean(train_losses) if train_losses else 0.0
        train_accuracy = train_correct / train_total if train_total > 0 else 0.0
        results['train_loss'].append(avg_train_loss)
        results['train_accuracy'].append(train_accuracy)

        # Validation
        val_loss, val_accuracy, predictions, true_labels = _evaluate_classifier(
            model, val_data, processor, max_length, batch_size
        )
        results['val_loss'].append(val_loss)
        results['val_accuracy'].append(val_accuracy)

        # Learning rate scheduling
        if val_accuracy > best_val_acc + 0.01:
            best_val_acc = val_accuracy
            patience_counter = 0
        else:
            patience_counter += 1
            if patience_counter >= patience:
                current_lr *= 0.5
                patience_counter = 0
                if current_lr < 1e-5:
                    print(f"\nLearning rate too small, stopping early at epoch {epoch + 1}")
                    break
                print(f"\nReducing learning rate to {current_lr:.6f}")

        # Print progress
        print(f"Epoch {epoch + 1}/{num_epochs} - "
              f"Loss: {avg_train_loss:.4f}, Acc: {train_accuracy:.3f}, "
              f"Val Loss: {val_loss:.4f}, Val Acc: {val_accuracy:.3f}, "
              f"LR: {current_lr:.6f}")

    # Compute final confusion matrix
    _, _, predictions, true_labels = _evaluate_classifier(
        model, val_data, processor, max_length, batch_size
    )
    confusion_matrix = _compute_confusion_matrix(predictions, true_labels, model.num_classes)
    results['confusion_matrix'] = confusion_matrix

    print("\n" + "=" * 60)
    print("Sentiment Classifier Training Complete!")
    print("=" * 60)
    print("\nConfusion Matrix:")
    print(confusion_matrix)

    results['model'] = model
    results['processor'] = processor
    return results


# ==================== Private Helper Functions ====================

def _compute_loss_and_gradients(logits, targets, lengths, pad_idx):
    """Compute cross-entropy loss and gradients."""
    batch_size, seq_len, vocab_size = logits.shape

    # Softmax
    probs = np.exp(logits - np.max(logits, axis=-1, keepdims=True))
    probs = probs / (np.sum(probs, axis=-1, keepdims=True) + 1e-9)

    # Cross-entropy and gradients
    total_loss = 0.0
    total_tokens = 0
    dlogits = np.zeros_like(logits)

    for i in range(batch_size):
        for t in range(min(lengths[i], seq_len)):
            if t < seq_len and targets[i, t] != pad_idx and targets[i, t] < vocab_size:
                prob = probs[i, t, targets[i, t]]
                total_loss -= np.log(prob + 1e-9)

                # Gradient: softmax derivative
                dlogits[i, t, :] = probs[i, t, :]
                dlogits[i, t, targets[i, t]] -= 1.0
                total_tokens += 1

    # Normalize
    if total_tokens > 0:
        total_loss /= total_tokens
        dlogits /= total_tokens

    return total_loss, dlogits


def _compute_classification_loss_and_gradients(logits, labels):
    """Compute classification loss and gradients."""
    # Softmax
    exp_logits = np.exp(logits - np.max(logits, axis=-1, keepdims=True))
    probs = exp_logits / (np.sum(exp_logits, axis=-1, keepdims=True) + 1e-9)

    # Cross-entropy
    batch_size = len(labels)
    loss = 0.0
    dlogits = np.zeros_like(logits)

    for i in range(batch_size):
        loss -= np.log(probs[i, labels[i]] + 1e-9)

        # Gradient
        dlogits[i, :] = probs[i, :]
        dlogits[i, labels[i]] -= 1.0

    loss /= batch_size
    dlogits /= batch_size

    return loss, dlogits


def _clip_model_gradients(model, max_norm):
    """Clip all gradients in the model."""
    total_norm = 0.0

    # Collect all gradient arrays
    grad_arrays = []

    # Model-level gradients
    if hasattr(model, 'dembedding'):
        grad_arrays.append(model.dembedding)
    if hasattr(model, 'doutput_proj'):
        grad_arrays.append(model.doutput_proj)
    if hasattr(model, 'doutput_bias'):
        grad_arrays.append(model.doutput_bias)

    # Cell gradients
    if hasattr(model, 'cell'):
        cell = model.cell
        for attr in dir(cell):
            if attr.startswith('dW_') or attr.startswith('db_'):
                val = getattr(cell, attr)
                if isinstance(val, np.ndarray):
                    grad_arrays.append(val)

    # Compute global norm
    for g in grad_arrays:
        total_norm += np.sum(g ** 2)
    total_norm = np.sqrt(total_norm)

    # Clip
    if total_norm > max_norm:
        clip_coef = max_norm / (total_norm + 1e-8)
        for g in grad_arrays:
            g *= clip_coef


def _sgd_update(model, lr):
    """Apply SGD update to model parameters."""
    # Update embedding
    if hasattr(model, 'embedding') and hasattr(model, 'dembedding'):
        model.embedding -= lr * np.clip(model.dembedding, -1.0, 1.0)
        model.dembedding.fill(0)

    # Update output projection
    if hasattr(model, 'output_proj') and hasattr(model, 'doutput_proj'):
        model.output_proj -= lr * np.clip(model.doutput_proj, -1.0, 1.0)
        model.doutput_proj.fill(0)

    if hasattr(model, 'output_bias') and hasattr(model, 'doutput_bias'):
        model.output_bias -= lr * np.clip(model.doutput_bias, -1.0, 1.0)
        model.doutput_bias.fill(0)

    # Update cell parameters
    if hasattr(model, 'cell'):
        cell = model.cell

        # Update all parameters
        param_names = []

        if model.cell_type == 'vanilla':
            param_names = [('W_xh', 'dW_xh'), ('W_hh', 'dW_hh'), ('b_h', 'db_h')]
        elif model.cell_type == 'lstm':
            param_names = [
                ('W_xf', 'dW_xf'), ('W_hf', 'dW_hf'), ('b_f', 'db_f'),
                ('W_xi', 'dW_xi'), ('W_hi', 'dW_hi'), ('b_i', 'db_i'),
                ('W_xc', 'dW_xc'), ('W_hc', 'dW_hc'), ('b_c', 'db_c'),
                ('W_xo', 'dW_xo'), ('W_ho', 'dW_ho'), ('b_o', 'db_o')
            ]
        elif model.cell_type == 'gru':
            param_names = [
                ('W_xr', 'dW_xr'), ('W_hr', 'dW_hr'), ('b_r', 'db_r'),
                ('W_xz', 'dW_xz'), ('W_hz', 'dW_hz'), ('b_z', 'db_z'),
                ('W_xh', 'dW_xh'), ('W_hh', 'dW_hh'), ('b_h', 'db_h')
            ]

        for param_name, grad_name in param_names:
            if hasattr(cell, param_name) and hasattr(cell, grad_name):
                param = getattr(cell, param_name)
                grad = getattr(cell, grad_name)
                if isinstance(param, np.ndarray) and isinstance(grad, np.ndarray):
                    clipped_grad = np.clip(grad, -1.0, 1.0)
                    setattr(cell, param_name, param - lr * clipped_grad)
                    grad.fill(0)


def _backward_through_time(model, dlogits, cache):
    """Perform backpropagation through time."""
    if not isinstance(cache, dict):
        return

    input_ids = cache['input_ids']
    embedded = cache['embedded']
    hidden_states = cache['hidden_states']
    caches = cache['caches']
    cell_type = cache['cell_type']

    batch_size, seq_len, hidden_dim = hidden_states.shape
    vocab_size = model.vocab_size

    # Initialize embedding gradients
    if not hasattr(model, 'dembedding'):
        model.dembedding = np.zeros_like(model.embedding)
    else:
        model.dembedding.fill(0)

    if not hasattr(model, 'doutput_proj'):
        model.doutput_proj = np.zeros_like(model.output_proj)
    else:
        model.doutput_proj.fill(0)

    if not hasattr(model, 'doutput_bias'):
        model.doutput_bias = np.zeros_like(model.output_bias)
    else:
        model.doutput_bias.fill(0)

    # Backprop through output projection
    # dlogits shape: [batch_size, seq_len, vocab_size]
    # hidden_states shape: [batch_size, seq_len, hidden_dim]

    for t in range(seq_len):
        model.doutput_proj += hidden_states[:, t, :].T @ dlogits[:, t, :]
        model.doutput_bias += np.sum(dlogits[:, t, :], axis=0)

    # Backprop through hidden states
    dhidden = dlogits @ model.output_proj.T  # [batch_size, seq_len, hidden_dim]

    # Backprop through RNN cells
    dh_next = np.zeros((batch_size, hidden_dim))
    if cell_type == 'lstm':
        dc_next = np.zeros((batch_size, hidden_dim))

    # Initialize cell gradients
    if hasattr(model.cell, 'zero_grad'):
        model.cell.zero_grad()

    # Backward through time
    for t in reversed(range(seq_len)):
        dh = dhidden[:, t, :] + dh_next

        if cell_type == 'lstm':
            dx, dh_prev, dc_prev = model.cell.backward(dh, dc_next, caches[t])
            dc_next = dc_prev
        else:
            dx, dh_prev = model.cell.backward(dh, caches[t])

        dh_next = dh_prev

        # Accumulate embedding gradients
        for b in range(batch_size):
            token_id = input_ids[b, t]
            if 0 <= token_id < vocab_size:
                model.dembedding[token_id] += dx[b]


def _compute_cross_entropy_loss(logits, targets, lengths, pad_idx):
    """Compute cross-entropy loss with masking (no gradients)."""
    batch_size, seq_len, vocab_size = logits.shape

    # Softmax
    probs = np.exp(logits - np.max(logits, axis=-1, keepdims=True))
    probs = probs / (np.sum(probs, axis=-1, keepdims=True) + 1e-9)

    # Cross-entropy
    total_loss = 0.0
    total_tokens = 0

    for i in range(batch_size):
        for t in range(min(lengths[i], seq_len)):
            if t < seq_len and targets[i, t] != pad_idx and targets[i, t] < vocab_size:
                prob = probs[i, t, targets[i, t]]
                total_loss -= np.log(prob + 1e-9)
                total_tokens += 1

    return total_loss / max(total_tokens, 1)


def _compute_classification_loss(logits, labels):
    """Compute cross-entropy loss for classification."""
    # Softmax
    exp_logits = np.exp(logits - np.max(logits, axis=-1, keepdims=True))
    probs = exp_logits / np.sum(exp_logits, axis=-1, keepdims=True)

    # Cross-entropy
    batch_size = len(labels)
    loss = 0.0
    for i in range(batch_size):
        loss -= np.log(probs[i, labels[i]] + 1e-9)

    return loss / batch_size


def _evaluate_language_model(model, text, processor, seq_len):
    """Evaluate language model on validation data."""
    if len(text) < seq_len + 1:
        # If validation text is too short, use what we have
        seq_len = max(10, len(text) // 2)

    total_loss = 0.0
    num_tokens = 0

    # Sample multiple chunks from the text
    num_samples = min(5, max(1, len(text) // seq_len))

    for sample_idx in range(num_samples):
        start_idx = (sample_idx * len(text)) // num_samples
        end_idx = min(start_idx + seq_len + 1, len(text))

        if end_idx - start_idx < 2:
            continue

        chunk = text[start_idx:end_idx]

        # Prepare input and target
        input_seq = chunk[:-1]
        target_seq = chunk[1:]

        if len(input_seq) == 0:
            continue

        input_ids = processor.encode(input_seq)[np.newaxis, :]
        target_ids = processor.encode(target_seq)[np.newaxis, :]

        if input_ids.shape[1] == 0 or target_ids.shape[1] == 0:
            continue

        # Forward pass
        try:
            logits, _ = model.forward(input_ids)

            # Compute loss
            probs = np.exp(logits - np.max(logits, axis=-1, keepdims=True))
            probs = probs / (np.sum(probs, axis=-1, keepdims=True) + 1e-9)

            seq_length = min(target_ids.shape[1], logits.shape[1])
            for t in range(seq_length):
                target_token = target_ids[0, t]
                if 0 <= target_token < probs.shape[2]:
                    prob = probs[0, t, target_token]
                    total_loss -= np.log(prob + 1e-9)
                    num_tokens += 1
        except Exception as e:
            continue

    return total_loss / max(num_tokens, 1)


def _evaluate_classifier(model, data, processor, max_length, batch_size):
    """Evaluate classifier on validation data."""
    losses = []
    predictions_all = []
    labels_all = []

    for i in range(0, len(data), batch_size):
        batch_data = data[i:i + batch_size]

        batch_texts = [text for text, _ in batch_data]
        batch_labels = np.array([label for _, label in batch_data], dtype=np.int32)

        # Encode
        batch_encoded = [processor.encode(text) for text in batch_texts]
        lengths = np.array([min(len(seq), max_length) for seq in batch_encoded], dtype=np.int32)

        # Pad
        input_ids = np.zeros((len(batch_encoded), max_length), dtype=np.int32)
        for j, seq in enumerate(batch_encoded):
            trunc = seq[:max_length]
            input_ids[j, :len(trunc)] = trunc

        # Forward
        logits = model.forward(input_ids, lengths)

        # Loss
        loss = _compute_classification_loss(logits, batch_labels)
        losses.append(loss)

        # Predictions
        preds = np.argmax(logits, axis=1)
        predictions_all.extend(preds.tolist())
        labels_all.extend(batch_labels.tolist())

    avg_loss = np.mean(losses) if losses else 0.0
    accuracy = np.mean(np.array(predictions_all) == np.array(labels_all))

    return avg_loss, accuracy, predictions_all, labels_all


def _compute_confusion_matrix(predictions, labels, num_classes):
    """Compute confusion matrix."""
    cm = np.zeros((num_classes, num_classes), dtype=np.int32)
    for pred, label in zip(predictions, labels):
        cm[label, pred] += 1
    return cm


