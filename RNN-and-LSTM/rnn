import numpy as np
from typing import Dict, List, Tuple, Optional, Union


# ==================== Helper Functions ====================

def xavier(shape):
    """Xavier initialization method for setting up weights.."""
    limit = np.sqrt(6 / sum(shape))
    return np.random.uniform(-limit, limit, shape)


def sigmoid(x):
    """Numerically stable sigmoid function."""
    return 1.0 / (1.0 + np.exp(-np.clip(x, -500, 500)))


# ==================== Part 1: RNN Cells ====================

class VanillaRNNCell:
    """This is the basic, standard Recurrent Neural Network (RNN) cell.
    It has a very simple structure, prone to the vanishing gradients problem.."""

    def __init__(self, input_dim: int, hidden_dim: int):
        """
        Initialize RNN cell parameters.

        Args:
            input_dim: Dimension of input vectors
            hidden_dim: Dimension of hidden state
        """
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim

        # Initialize weights and biases
        # This is the Xavier limit calculation again for W_xh and W_hh combo.

        limit = np.sqrt(6 / (input_dim + hidden_dim))
        # Weight matrix for input to hidden
        self.W_xh = np.random.uniform(-limit, limit, (input_dim, hidden_dim))
        # Weight matrix for previous hidden to hidden (recurrent weight)
        self.W_hh = np.random.uniform(-limit, limit, (hidden_dim, hidden_dim))
        # Bias vector, only for the hidden state update
        self.b_h = np.zeros((hidden_dim,))

        # Gradients
        self.dW_xh = np.zeros_like(self.W_xh)
        self.dW_hh = np.zeros_like(self.W_hh)
        self.db_h = np.zeros_like(self.b_h)

    def forward(self, x: np.ndarray, h_prev: np.ndarray) -> Tuple[np.ndarray, Dict]:
        """
        Forward pass of RNN cell.

        Args:
            x: Input at current timestep [batch_size, input_dim]
            h_prev: Hidden state from previous timestep [batch_size, hidden_dim]

        Returns:
            h: Hidden state at current timestep [batch_size, hidden_dim]
            cache: Values needed for backward pass
        """
        # The main computation: z = W_xh*x + W_hh*h_prev + b_h
        z = np.dot(x, self.W_xh) + np.dot(h_prev, self.W_hh) + self.b_h
        # Apply the non-linearity (tanh) to get the new hidden state
        h = np.tanh(z)

        cache = {
            'x': x,
            'h_prev': h_prev,
            'z': z,
            'h': h
        }

        return h, cache

    def backward(self, dh: np.ndarray, cache: Dict) -> Tuple[np.ndarray, np.ndarray]:
        """
        Backward pass of RNN cell.

        Args:
            dh: Gradient of loss w.r.t. hidden state [batch_size, hidden_dim]
            cache: Cache from forward pass

        Returns:
            dx: Gradient w.r.t. input [batch_size, input_dim]
            dh_prev: Gradient w.r.t. previous hidden state [batch_size, hidden_dim]
        """
        x = cache['x']
        h_prev = cache['h_prev']
        h = cache['h']

        # Gradient through tanh: dz = dL/dh * dh/dz = dh * (1 - h^2)
        dz = dh * (1 - h ** 2)

        # Parameter gradients (dL/dW and dL/db)
        # dW_xh = x.T @ dz
        self.dW_xh += np.dot(x.T, dz)
        # dW_hh = h_prev.T @ dz
        self.dW_hh += np.dot(h_prev.T, dz)
        # db_h = sum(dz) over batch dimension
        self.db_h += np.sum(dz, axis=0)

        # Input gradients (dL/dx and dL/dh_prev)
        # dx = dz @ W_xh.T
        dx = np.dot(dz, self.W_xh.T)
        # dh_prev = dz @ W_hh.T (this goes back in time!)
        dh_prev = np.dot(dz, self.W_hh.T)

        return dx, dh_prev

    def zero_grad(self):
        """Zero out accumulated gradients."""
        self.dW_xh.fill(0)
        self.dW_hh.fill(0)
        self.db_h.fill(0)


class LSTMCell:
    """LSTM cell implementation."""

    def __init__(self, input_dim: int, hidden_dim: int):
        """
        Initialize LSTM cell parameters.

        Args:
            input_dim: Dimension of input vectors
            hidden_dim: Dimension of hidden state
        """
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim

        # Initialize weights for all gates
        # Forget gate
        self.W_xf = xavier((input_dim, hidden_dim))
        self.W_hf = xavier((hidden_dim, hidden_dim))
        self.b_f = np.zeros((hidden_dim,))

        # Input gate
        self.W_xi = xavier((input_dim, hidden_dim))
        self.W_hi = xavier((hidden_dim, hidden_dim))
        self.b_i = np.zeros((hidden_dim,))

        # Candidate
        self.W_xc = xavier((input_dim, hidden_dim))
        self.W_hc = xavier((hidden_dim, hidden_dim))
        self.b_c = np.zeros((hidden_dim,))

        # Output gate
        self.W_xo = xavier((input_dim, hidden_dim))
        self.W_ho = xavier((hidden_dim, hidden_dim))
        self.b_o = np.zeros((hidden_dim,))

        # Initialize gradients
        self._init_gradients()

    def _init_gradients(self):
        """Initialize gradient s."""
        self.dW_xf = np.zeros_like(self.W_xf)
        self.dW_hf = np.zeros_like(self.W_hf)
        self.db_f = np.zeros_like(self.b_f)

        self.dW_xi = np.zeros_like(self.W_xi)
        self.dW_hi = np.zeros_like(self.W_hi)
        self.db_i = np.zeros_like(self.b_i)

        self.dW_xc = np.zeros_like(self.W_xc)
        self.dW_hc = np.zeros_like(self.W_hc)
        self.db_c = np.zeros_like(self.b_c)

        self.dW_xo = np.zeros_like(self.W_xo)
        self.dW_ho = np.zeros_like(self.W_ho)
        self.db_o = np.zeros_like(self.b_o)

    def forward(self, x: np.ndarray, h_prev: np.ndarray, c_prev: np.ndarray) -> Tuple[np.ndarray, np.ndarray, Dict]:
        """
        Forward pass of LSTM cell.

        Args:
            x: Input at current timestep [batch_size, input_dim]
            h_prev: Hidden state from previous timestep [batch_size, hidden_dim]
            c_prev: Cell state from previous timestep [batch_size, hidden_dim]

        Returns:
            h: Hidden state at current timestep [batch_size, hidden_dim]
            c: Cell state at current timestep [batch_size, hidden_dim]
            cache: Values needed for backward pass
        """
        # 1. Forget gate: decides what to forget from c_prev. Uses sigmoid.
        f = sigmoid(np.dot(x, self.W_xf) + np.dot(h_prev, self.W_hf) + self.b_f)
        # 2. Input gate: decides what new information to store in c_prev. Uses sigmoid.
        i = sigmoid(np.dot(x, self.W_xi) + np.dot(h_prev, self.W_hi) + self.b_i)
        # 3. Candidate cell state: new potential values for cell state. Uses tanh.
        c_tilde = np.tanh(np.dot(x, self.W_xc) + np.dot(h_prev, self.W_hc) + self.b_c)
        # 4. Update cell state: c = f*c_prev + i*c_tilde. This is the main highway!
        c = f * c_prev + i * c_tilde
        # 5. Output gate: decides what parts of the cell state to output (h). Uses sigmoid.
        o = sigmoid(np.dot(x, self.W_xo) + np.dot(h_prev, self.W_ho) + self.b_o)
        # 6. New hidden state: h = o*tanh(c)
        h = o * np.tanh(c)

        cache = {
            'x': x,
            'h_prev': h_prev,
            'c_prev': c_prev,
            'f': f,
            'i': i,
            'c_tilde': c_tilde,
            'o': o,
            'c': c,
            'h': h
        }

        return h, c, cache

    def backward(self, dh: np.ndarray, dc: np.ndarray, cache: Dict) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
        """
        Backward pass of LSTM cell.

        Args:
            dh: Gradient of loss w.r.t. hidden state [batch_size, hidden_dim]
            dc: Gradient of loss w.r.t. cell state [batch_size, hidden_dim]
            cache: Cache from forward pass

        Returns:
            dx: Gradient w.r.t. input [batch_size, input_dim]
            dh_prev: Gradient w.r.t. previous hidden state [batch_size, hidden_dim]
            dc_prev: Gradient w.r.t. previous cell state [batch_size, hidden_dim]
        """
        x = cache['x']
        h_prev = cache['h_prev']
        c_prev = cache['c_prev']
        f = cache['f']
        i = cache['i']
        c_tilde = cache['c_tilde']
        o = cache['o']
        c = cache['c']
        h = cache['h']

        # Gradients for output gate and cell state
        do = dh * np.tanh(c)
        dc_total = dh * o * (1 - np.tanh(c) ** 2) + dc

        # Gate contributions to cell state
        df = dc_total * c_prev
        di = dc_total * c_tilde
        dc_tilde = dc_total * i
        dc_prev = dc_total * f

        # Gate activation derivatives
        do_act = do * o * (1 - o)
        df_act = df * f * (1 - f)
        di_act = di * i * (1 - i)
        dc_tilde_act = dc_tilde * (1 - c_tilde ** 2)

        # Parameter gradients
        self.dW_xf += np.dot(x.T, df_act)
        self.dW_hf += np.dot(h_prev.T, df_act)
        self.db_f += np.sum(df_act, axis=0)

        self.dW_xi += np.dot(x.T, di_act)
        self.dW_hi += np.dot(h_prev.T, di_act)
        self.db_i += np.sum(di_act, axis=0)

        self.dW_xc += np.dot(x.T, dc_tilde_act)
        self.dW_hc += np.dot(h_prev.T, dc_tilde_act)
        self.db_c += np.sum(dc_tilde_act, axis=0)

        self.dW_xo += np.dot(x.T, do_act)
        self.dW_ho += np.dot(h_prev.T, do_act)
        self.db_o += np.sum(do_act, axis=0)

        # Input gradients
        dx = (np.dot(df_act, self.W_xf.T) +
              np.dot(di_act, self.W_xi.T) +
              np.dot(dc_tilde_act, self.W_xc.T) +
              np.dot(do_act, self.W_xo.T))

        dh_prev = (np.dot(df_act, self.W_hf.T) +
                   np.dot(di_act, self.W_hi.T) +
                   np.dot(dc_tilde_act, self.W_hc.T) +
                   np.dot(do_act, self.W_ho.T))

        return dx, dh_prev, dc_prev

    def zero_grad(self):
        """Zero out accumulated gradients."""
        self.dW_xf.fill(0)
        self.dW_hf.fill(0)
        self.db_f.fill(0)
        self.dW_xi.fill(0)
        self.dW_hi.fill(0)
        self.db_i.fill(0)
        self.dW_xc.fill(0)
        self.dW_hc.fill(0)
        self.db_c.fill(0)
        self.dW_xo.fill(0)
        self.dW_ho.fill(0)
        self.db_o.fill(0)


class GRUCell:
    """GRU cell implementation."""

    def __init__(self, input_dim: int, hidden_dim: int):
        """
        Initialize GRU cell parameters.

        Args:
            input_dim: Dimension of input vectors
            hidden_dim: Dimension of hidden state
        """
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim

        # Reset gate
        self.W_xr = xavier((input_dim, hidden_dim))
        self.W_hr = xavier((hidden_dim, hidden_dim))
        self.b_r = np.zeros((hidden_dim,))

        # Update gate
        self.W_xz = xavier((input_dim, hidden_dim))
        self.W_hz = xavier((hidden_dim, hidden_dim))
        self.b_z = np.zeros((hidden_dim,))

        # Candidate
        self.W_xh = xavier((input_dim, hidden_dim))
        self.W_hh = xavier((hidden_dim, hidden_dim))
        self.b_h = np.zeros((hidden_dim,))

        self._init_gradients()

    def _init_gradients(self):
        """Initialize gradient s."""
        self.dW_xr = np.zeros_like(self.W_xr)
        self.dW_hr = np.zeros_like(self.W_hr)
        self.db_r = np.zeros_like(self.b_r)
        self.dW_xz = np.zeros_like(self.W_xz)
        self.dW_hz = np.zeros_like(self.W_hz)
        self.db_z = np.zeros_like(self.b_z)
        self.dW_xh = np.zeros_like(self.W_xh)
        self.dW_hh = np.zeros_like(self.W_hh)
        self.db_h = np.zeros_like(self.b_h)

    def forward(self, x: np.ndarray, h_prev: np.ndarray) -> Tuple[np.ndarray, Dict]:
        """
        Forward pass of GRU cell.

        Args:
            x: Input at current timestep [batch_size, input_dim]
            h_prev: Hidden state from previous timestep [batch_size, hidden_dim]

        Returns:
            h: Hidden state at current timestep [batch_size, hidden_dim]
            cache: Values needed for backward pass
        """
        # 1. Reset Gate (r): decides how much of the past hidden state to use for the candidate h_tilde.
        r = sigmoid(np.dot(x, self.W_xr) + np.dot(h_prev, self.W_hr) + self.b_r)
        # 2. Update Gate (z): controls the flow from h_prev to h_t.
        z = sigmoid(np.dot(x, self.W_xz) + np.dot(h_prev, self.W_hz) + self.b_z)
        # 3. Candidate Hidden State (h_tilde): the new proposed hidden state. Note the r * h_prev term!
        h_tilde = np.tanh(np.dot(x, self.W_xh) + np.dot(r * h_prev, self.W_hh) + self.b_h)
        # 4. Final Hidden State (h): combines h_prev and h_tilde using the update gate z.
        h = (1 - z) * h_prev + z * h_tilde

        cache = {
            'x': x,
            'h_prev': h_prev,
            'r': r,
            'z': z,
            'h_tilde': h_tilde,
            'h': h
        }

        return h, cache

    def backward(self, dh: np.ndarray, cache: Dict) -> Tuple[np.ndarray, np.ndarray]:
        """
        Backward pass of GRU cell.

        Args:
            dh: Gradient of loss w.r.t. hidden state [batch_size, hidden_dim]
            cache: Cache from forward pass

        Returns:
            dx: Gradient w.r.t. input [batch_size, input_dim]
            dh_prev: Gradient w.r.t. previous hidden state [batch_size, hidden_dim]
        """
        # FIXED: Use h_tilde instead of h_hat
        x = cache['x']
        h_prev = cache['h_prev']
        r = cache['r']
        z = cache['z']
        h_tilde = cache['h_tilde']  # CRITICAL FIX
        h = cache['h']

        # Gradient through output combination: h = (1-z)*h_prev + z*h_tilde
        dz = dh * (h_tilde - h_prev)
        dh_tilde = dh * z
        dh_prev_direct = dh * (1 - z)

        # Gradient through tanh for candidate
        dtanh = dh_tilde * (1 - h_tilde ** 2)

        # Gradient through reset gate
        dr = np.dot(dtanh, self.W_hh.T) * h_prev

        # Gate activation derivatives
        dr_act = dr * r * (1 - r)
        dz_act = dz * z * (1 - z)

        # Parameter gradients
        self.dW_xr += np.dot(x.T, dr_act)
        self.dW_hr += np.dot(h_prev.T, dr_act)
        self.db_r += np.sum(dr_act, axis=0)

        self.dW_xz += np.dot(x.T, dz_act)
        self.dW_hz += np.dot(h_prev.T, dz_act)
        self.db_z += np.sum(dz_act, axis=0)

        self.dW_xh += np.dot(x.T, dtanh)
        self.dW_hh += np.dot((r * h_prev).T, dtanh)
        self.db_h += np.sum(dtanh, axis=0)

        # Input gradients
        dx = (np.dot(dr_act, self.W_xr.T) +
              np.dot(dz_act, self.W_xz.T) +
              np.dot(dtanh, self.W_xh.T))

        dh_prev = (dh_prev_direct +
                   np.dot(dr_act, self.W_hr.T) +
                   np.dot(dz_act, self.W_hz.T) +
                   np.dot(dtanh, self.W_hh.T) * r)

        return dx, dh_prev

    def zero_grad(self):
        """Zero out accumulated gradients."""
        self.dW_xr.fill(0)
        self.dW_hr.fill(0)
        self.db_r.fill(0)
        self.dW_xz.fill(0)
        self.dW_hz.fill(0)
        self.db_z.fill(0)
        self.dW_xh.fill(0)
        self.dW_hh.fill(0)
        self.db_h.fill(0)


# ==================== Part 2: Attention Mechanisms ====================

def scaled_dot_product_attention(Q: np.ndarray, K: np.ndarray, V: np.ndarray,
                                 mask: Optional[np.ndarray] = None) -> Tuple[np.ndarray, np.ndarray]:
    """
    Compute scaled dot-product attention.

    Args:
        Q: Query matrix [batch_size, seq_len_q, d_k]
        K: Key matrix [batch_size, seq_len_k, d_k]
        V: Value matrix [batch_size, seq_len_v, d_v]
        mask: Optional mask [batch_size, seq_len_q, seq_len_k]
              Convention: 1 = mask out (set to -inf), 0 = keep

    Returns:
        output: Attention output [batch_size, seq_len_q, d_v]
        attention_weights: Attention weights [batch_size, seq_len_q, seq_len_k]
    """
    Q = Q.astype(np.float32)
    K = K.astype(np.float32)
    V = V.astype(np.float32)

    d_k = Q.shape[-1]

    # Compute attention scores: Q @ K^T / sqrt(d_k)
    scores = np.matmul(Q, np.swapaxes(K, -2, -1)) / np.sqrt(d_k)

    # Apply mask if provided (mask==1 means mask out)
    if mask is not None:
        mask_expanded = mask
        while mask_expanded.ndim < scores.ndim:
            mask_expanded = np.expand_dims(mask_expanded, axis=0)
        # Set masked positions to large negative value
        scores = np.where(mask_expanded == 1, -1e9, scores)

    # Stable softmax
    scores_max = np.max(scores, axis=-1, keepdims=True)
    exp_scores = np.exp(scores - scores_max)
    attention_weights = exp_scores / (np.sum(exp_scores, axis=-1, keepdims=True) + 1e-9)

    # Apply attention to values
    output = np.matmul(attention_weights, V)

    return output, attention_weights


class MultiHeadSelfAttention:
    """Multi-head self-attention layer."""

    def __init__(self, d_model: int, num_heads: int):
        """
        Initialize multi-head attention.

        Args:
            d_model: Model dimension
            num_heads: Number of attention heads
        """
        assert d_model % num_heads == 0

        self.d_model = d_model
        self.num_heads = num_heads
        self.d_k = d_model // num_heads

        # Initialize projection matrices
        self.W_q = xavier((d_model, d_model))
        self.W_k = xavier((d_model, d_model))
        self.W_v = xavier((d_model, d_model))
        self.W_o = xavier((d_model, d_model))

    def forward(self, x: np.ndarray, mask: Optional[np.ndarray] = None) -> Tuple[np.ndarray, np.ndarray]:
        """
        Forward pass of multi-head self-attention.

        Args:
            x: Input tensor [batch_size, seq_len, d_model]
            mask: Optional attention mask

        Returns:
            output: Attention output [batch_size, seq_len, d_model]
            attention_weights: Attention weights [batch_size, num_heads, seq_len, seq_len]
        """
        x = x.astype(np.float32)
        batch_size, seq_len, _ = x.shape

        # Project to Q, K, V
        Q = np.matmul(x, self.W_q)  # [B, S, d_model]
        K = np.matmul(x, self.W_k)
        V = np.matmul(x, self.W_v)

        # Reshape for multiple heads: [B, S, d_model] -> [B, num_heads, S, d_k]
        Q = Q.reshape(batch_size, seq_len, self.num_heads, self.d_k).transpose(0, 2, 1, 3)
        K = K.reshape(batch_size, seq_len, self.num_heads, self.d_k).transpose(0, 2, 1, 3)
        V = V.reshape(batch_size, seq_len, self.num_heads, self.d_k).transpose(0, 2, 1, 3)

        # Prepare mask for heads if provided
        if mask is not None:
            mask_for_heads = mask
            if mask_for_heads.ndim == 2:  # [S, S]
                mask_for_heads = mask_for_heads[None, None, :, :]
            elif mask_for_heads.ndim == 3:  # [B, S, S]
                mask_for_heads = mask_for_heads[:, None, :, :]
        else:
            mask_for_heads = None

        # Compute attention for all heads (vectorized)
        scores = np.matmul(Q, np.swapaxes(K, -2, -1)) / np.sqrt(self.d_k)  # [B, H, S, S]

        if mask_for_heads is not None:
            scores = np.where(mask_for_heads == 1, -1e9, scores)

        # Softmax
        scores_max = np.max(scores, axis=-1, keepdims=True)
        exp_scores = np.exp(scores - scores_max)
        attention_weights = exp_scores / (np.sum(exp_scores, axis=-1, keepdims=True) + 1e-9)

        # Apply attention
        attn_output = np.matmul(attention_weights, V)  # [B, H, S, d_k]

        # Concatenate heads: [B, H, S, d_k] -> [B, S, d_model]
        attn_output = attn_output.transpose(0, 2, 1, 3).reshape(batch_size, seq_len, self.d_model)

        # Final projection
        output = np.matmul(attn_output, self.W_o)

        return output, attention_weights


def positional_encoding(seq_len: int, d_model: int) -> np.ndarray:
    """
    Generate positional encoding.

    Args:
        seq_len: Sequence length
        d_model: Model dimension

    Returns:
        pos_encoding: Positional encoding matrix [seq_len, d_model]
    """
    pos_encoding = np.zeros((seq_len, d_model))
    positions = np.arange(seq_len)[:, np.newaxis]
    # The division term 1 / (10000^(2i/d_model)) in log space
    div_terms = np.exp(np.arange(0, d_model, 2) * -(np.log(10000.0) / d_model))

    # Apply sin to even indices (0, 2, 4, ...)
    pos_encoding[:, 0::2] = np.sin(positions * div_terms)
    # Apply cos to odd indices (1, 3, 5, ...)
    pos_encoding[:, 1::2] = np.cos(positions * div_terms)

    return pos_encoding


