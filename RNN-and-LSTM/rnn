                if prompt_ids.shape[1] > 0:
                    generated_ids = trained_model.generate(prompt_ids, max_length=100, temperature=0.7)
                    sample_text = processor_lm.decode(generated_ids[0])
                    print(f"\nPrompt: '{prompt}'")
                    print(f"Generated: {sample_text}")
            except Exception as e:
                print(f"Error generating from prompt '{prompt}': {e}")

        print("\n" + "=" * 60)
        print(f"Final Training Perplexity: {lm_results['train_perplexity'][-1]:.2f}")
        print(f"Final Validation Perplexity: {lm_results['val_perplexity'][-1]:.2f}")
        print("=" * 60)
    else:
        print("shakespeare.txt not found - skipping language model training")

    # ========== PART 2: Sentiment Classification ==========
    print("\n\n### PART 2: SENTIMENT ANALYSIS WITH BiLSTM CLASSIFIER ###\n")

    # Load review data
    reviews = load_review_data('reviews.csv')

    if reviews:
        print(f"Loaded {len(reviews)} movie reviews")

        # Split into train/val
        train_reviews, val_reviews = split_review_data(reviews, train_ratio=0.8)
        print(f"Train: {len(train_reviews)} reviews, Val: {len(val_reviews)} reviews")

        # Create text processor
        processor_clf = TextProcessor(level='word')
        all_review_texts = [text for text, _ in reviews]
        processor_clf.build_vocab(all_review_texts, min_freq=1)

        # Create classifier
        print(f"\nCreating BiLSTM Classifier (vocab_size={processor_clf.vocab_size})...")
        clf_model = BiLSTMClassifier(
            vocab_size=processor_clf.vocab_size,
            hidden_dim=64,
            num_classes=2,
            use_attention=True
        )

        # Training configuration
        clf_config = {
            'num_epochs': 20,
            'batch_size': 4,
            'max_length': 100,
            'learning_rate': 0.01,
            'clip_norm': 5.0
        }

        # Train the classifier
        clf_results = train_classifier(clf_model, train_reviews, val_reviews, clf_config)

        # Use the trained model and processor from results
        trained_clf = clf_results.get('model', clf_model)
        processor_clf = clf_results.get('processor', processor_clf)

        # Test on sample reviews
        print("\n### SAMPLE PREDICTIONS ###")
        test_samples = val_reviews[:5]

        for text, true_label in test_samples:
            try:
                input_ids = processor_clf.encode(text)[:100]

                # Pad to max_length
                padded_ids = np.zeros((1, 100), dtype=np.int32)
                padded_ids[0, :len(input_ids)] = input_ids

                length = np.array([min(len(input_ids), 100)])

                # Get prediction
                logits = trained_clf.forward(padded_ids, length)
                pred_label = np.argmax(logits[0])

                # Compute confidence
                exp_logits = np.exp(logits[0] - np.max(logits[0]))
                probs = exp_logits / np.sum(exp_logits)
                confidence = probs[pred_label]

                label_names = {0: 'Negative', 1: 'Positive'}
                print(f"\nText: {text[:80]}...")
                print(f"True: {label_names[true_label]}, "
                      f"Predicted: {label_names[pred_label]}, "
                      f"Confidence: {confidence:.3f}")
            except Exception as e:
                print(f"Error predicting review: {e}")

        print("\n" + "=" * 60)
        print(f"Final Training Accuracy: {clf_results['train_accuracy'][-1]:.3f}")
        print(f"Final Validation Accuracy: {clf_results['val_accuracy'][-1]:.3f}")
        print("=" * 60)
    else:
        print("reviews.csv not found - skipping classifier training")
